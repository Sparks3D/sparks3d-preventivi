{
  "productName": "Sparks3D Preventivi",
  "version": "1.3.0",
  "identifier": "com.sparks3d.preventivi",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sparks3D Preventivi",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Sparks3D",
        "url": "splashscreen.html",
        "width": 580,
        "height": 380,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src ipc: http://ipc.localhost; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "both",
        "languages": ["Italian", "English"],
        "startMenuFolder": "Sparks3D"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3RjBEOTYyOTI3NjdERDQKUldUVWZYYVNZdG53bDdhZnlhSVF4a3EveDZLR0xrbnl6d1EyelJuRkVsS0o5SzlITURUblVUZ2YK",
      "endpoints": [
        "https://github.com/Sparks3D/sparks3d-preventivi/releases/latest/download/latest.json",
        "https://sparks3d.it/updates/latest.json"
      ]
    }
  }
}
